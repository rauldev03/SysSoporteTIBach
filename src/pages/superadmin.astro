---
// src/pages/superadmin.astro
import Layout from "@/layouts/Layout.astro";
import { createSupabaseServerClient } from "@/lib/supabase/server";
import LogoutButton from "@/components/LogoutButton";
import UserManager from "@/components/UserManager";

const supabase = createSupabaseServerClient(Astro.cookies);

// Verificar sesión
const {
    data: { user },
} = await supabase.auth.getUser();

if (!user) {
    return Astro.redirect("/login");
}

// Verificar que sea superadmin
const { data: profile } = await supabase
    .from("profiles")
    .select("role")
    .eq("id", user.id)
    .single();

if (profile?.role !== "superadmin") {
    // Si no es superadmin, rechazarlo. Podríamos enviarlo a su dashboard.
    const redirectUrl = profile?.role === "administrador" ? "/admin" : "/dashboard";
    return Astro.redirect(redirectUrl);
}
---

<Layout title="Gestión de Usuarios - Superadmin">
    <div class="bg-slate-50 min-h-screen p-4 sm:p-8">
        <div class="max-w-7xl mx-auto space-y-8">
            <header class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 bg-white p-6 rounded-xl border border-slate-200 shadow-sm">
                <div>
                    <h1 class="text-3xl font-bold text-slate-900 tracking-tight">Panel de Superadmin</h1>
                    <p class="text-slate-500 mt-1">
                        Gestión global de usuarios y permisos (<span class="font-medium">{user.email}</span>)
                    </p>
                </div>
                <div class="flex items-center gap-4">
                    <LogoutButton client:load />
                </div>
            </header>

            <main>
                <UserManager client:load />
            </main>
        </div>
    </div>
</Layout>
